# Web 管理面板
WEB_PORT=5000
# SOCKS5 入站代理
SOCKS5_PORT=5001
# HTTP/HTTPS 入站代理
HTTP_PROXY_PORT=5002

# 运行模式
TEST_MODE=tcp
AUTO_FETCH=true
AUTO_TEST=true
AUTO_FETCH_TYPE=all
AUTO_FETCH_COUNTRIES=US,JP,SG
AUTO_FETCH_LIMIT=100
AUTO_TEST_PROTOCOL=
AUTO_TEST_COUNT=150
FETCH_LIMIT_PER_COUNTRY=100
POLL_INTERVAL=300
TEST_INTERVAL=120
TEST_COUNT=150
TIMEOUT=10
TEST_URL=https://www.google.com
LOG_LEVEL=INFO
# 是否把大量连接异常打到 error 日志；默认关闭降噪
LOG_CONNECTION_ERRORS=false
DATA_DIR=/app/data

# SOCKS5 入站配置
SOCKS5_ENABLED=true
SOCKS5_HOST=0.0.0.0
SOCKS5_AUTH=false
SOCKS5_USER=proxyuser
SOCKS5_PASS=proxypass
SOCKS5_ROTATE=request

# HTTP 入站配置
HTTP_PROXY_ENABLED=true
HTTP_PROXY_HOST=0.0.0.0
HTTP_PROXY_AUTH=false
HTTP_PROXY_USER=proxyuser
HTTP_PROXY_PASS=proxypass
